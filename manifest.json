{
  "manifest_version": 3,

  "name": "Docsense AI",

  "version": "1.0",

  "description": "AI documentation assistant",

  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "action": {
    "default_popup": "popup/popup.html"
  },

  "background": {
    "service_worker": "scripts/background.js"
  },

  "web_accessible_resources": [
    {
      "resources": [
        "images/*"
      ],

      "matches": [
        "<all_urls>"
      ]
    }
  ]
}